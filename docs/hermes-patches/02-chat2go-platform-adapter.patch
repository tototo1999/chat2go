+async def _extract_attachment_text(name: str, url: str, max_chars: int = 30000) -> str:
+    """
+    下载非图片附件并提取文本。失败返回描述字符串（不抛异常，让 AI 看到原因）。
+    支持：txt/md/csv/json/html/xml/log、pdf、docx
+    """
+    name_lower = name.lower()
+    try:
+        async with httpx.AsyncClient(timeout=30) as client:
+            resp = await client.get(url)
+            resp.raise_for_status()
+            data = resp.content
+    except Exception as e:
+        return f"[下载失败: {e}]"
+
+    text = ""
+
+    # 文本类
+    text_exts = (".txt", ".md", ".markdown", ".csv", ".json", ".html", ".htm", ".xml", ".log")
+    if name_lower.endswith(text_exts):
+        try:
+            text = data.decode("utf-8", errors="replace")
+        except Exception:
+            text = data.decode("latin-1", errors="replace")
+
+    # PDF
+    elif name_lower.endswith(".pdf"):
+        try:
+            from io import BytesIO
+            import pypdf
+            reader = pypdf.PdfReader(BytesIO(data))
+            text = "\n".join((p.extract_text() or "") for p in reader.pages)
+        except ImportError:
+            return "[PDF 解析需要 pypdf：在 hermes venv 装 pip install pypdf]"
+        except Exception as e:
+            return f"[PDF 解析失败: {e}]"
+
+    # DOCX
+    elif name_lower.endswith(".docx"):
+        try:
+            from io import BytesIO
+            import docx as _docx
+            doc = _docx.Document(BytesIO(data))
+            text = "\n".join(p.text for p in doc.paragraphs)
+        except ImportError:
+            return "[DOCX 解析需要 python-docx]"
+        except Exception as e:
+            return f"[DOCX 解析失败: {e}]"
+
+    # 音频:课堂录音 → 本地 mlx-whisper large-v3-turbo (Apple Silicon Metal 加速)
+    elif name_lower.endswith((".mp3", ".m4a", ".wav", ".aac", ".ogg", ".webm", ".flac", ".mp4")):
+        try:
+            import tempfile as _tempfile
+            import os as _os
+            import time as _time
+            import mlx_whisper
+            ext = "." + name_lower.rsplit(".", 1)[-1]
+            with _tempfile.NamedTemporaryFile(suffix=ext, delete=False) as f:
+                f.write(data)
+                tmp_path = f.name
+            try:
+                t0 = _time.time()
+                # 用 to_thread 把 sync mlx-whisper 跑到后台线程,不阻塞 event loop
+                # (33MB 转写 5+ min 期间 Hermes 仍能 polling/心跳/接其他消息)
+                result = await asyncio.to_thread(
+                    mlx_whisper.transcribe,
+                    tmp_path,
+                    path_or_hf_repo="mlx-community/whisper-large-v3-turbo",
+                )
+                elapsed = _time.time() - t0
+                transcript = (result.get("text") or "").strip()
+                if not transcript:
+                    return "[音频转写为空,请确认录音清晰]"
+                # 真实时长来自 mlx-whisper (segments 最后一个的 end)
+                segments = result.get("segments") or []
+                duration = segments[-1].get("end", 0) if segments else 0
+                approx_sec = int(duration) if duration else max(1, int(len(data) / 16384))
+                return f"【课堂录音转写 (约 {approx_sec} 秒, 本地 {elapsed:.1f}s 完成)】\n{transcript}"
+            finally:
+                try: _os.unlink(tmp_path)
+                except: pass
+        except ImportError:
+            return "[音频转写需要 mlx-whisper 库]"
+        except Exception as e:
+            return f"[音频转写失败: {type(e).__name__}: {e}]"
+
+    elif name_lower.endswith(".qta"):
+        return "[Apple 语音备忘录 .qta 暂不支持,请用 QuickTime 导出为 .m4a 再上传]"
+
+    else:
+        return f"[不支持的文件类型，可访问 URL: {url}]"
+
+    text = text.strip()
+    if not text:
+        return "[文件文本为空 / 无法提取]"
+    if len(text) > max_chars:
+        text = text[:max_chars] + f"\n\n[... 文件过长，已截断到 {max_chars} 字符 ...]"
+    return text
