+        if (self._rooms.get(chat_id) or {}).get("product") == "speak2go":
+            try:
+                import re as _re
+                _ma = _re.search(r'\[TODO_APPEND\](.+?)\[/TODO_APPEND\]', content, _re.S)
+                if _ma:
+                    _items = []
+                    for _line in _ma.group(1).strip().splitlines():
+                        _line = _line.strip()
+                        if not _line:
+                            continue
+                        if _line[0:1] in '-•*':
+                            _items.append({'label': _line.lstrip('-•*').strip()[:80]})
+                    if _items:
+                        try:
+                            # 拉 active template 并 append 新 group(同 handle_extract_todos 模式)
+                            _room_r = await self._sb.table('rooms').select('active_todo_template_id').eq('id', chat_id).maybe_single().execute()
+                            _tmpl_id = (_room_r.data or {}).get('active_todo_template_id') if _room_r else None
+                            if _tmpl_id:
+                                _tmpl_r = await self._sb.table('expert_todo_templates').select('id,payload').eq('id', _tmpl_id).maybe_single().execute()
+                                if _tmpl_r and _tmpl_r.data:
+                                    _payload = list(_tmpl_r.data.get('payload') or [])
+                                    _payload.append({
+                                        'label': f"📅 {datetime.now().strftime('%m-%d %H:%M')}",
+                                        'items': _items,
+                                    })
+                                    await self._sb.table('expert_todo_templates').update({'payload': _payload}).eq('id', _tmpl_id).execute()
+                                    logger.info("Chat2GO AI 写 todo (APPEND): room=%s items=%d", chat_id, len(_items))
+                                    _todo_updated = True
