+            if role == "expert" and self._is_memory_save_cmd(content):
+                t = asyncio.create_task(self._save_context_as_memory(room_id, msg))
+                if not hasattr(self, "_bg_tasks"):
+                    self._bg_tasks: set = set()
+                self._bg_tasks.add(t)
+                t.add_done_callback(self._bg_tasks.discard)
+
+            # ★ 2026-05-16:prefetch memories,prepend 到消息内容,让 Hermes 看到大咖记忆
+            try:
+                mem_ctx = await self._prefetch_memory(
+                    room_id=room_id,
+                    expert_id=self._expert_id,
+                    user_id=msg.get("user_id") if role == "user" else None,
+                )
+                if mem_ctx:
+                    content = f"<memory-context>\n{mem_ctx}\n</memory-context>\n\n{content}"
+            except Exception as me:
+                logger.debug("Chat2GO prefetch_memory 跳过: %s", me)
+
+            # ★ 2026-05-16 晚:quiz-state 注入已禁用 — AI 拿到题库会赶着推进做题,体验不好。
+            # _build_quiz_state 函数定义保留(无副作用),要重新启用直接取消下面注释即可。
+            # try:
+            #     quiz_ctx = await self._build_quiz_state(room_id)
+            #     if quiz_ctx:
+            #         content = f"{quiz_ctx}\n\n{content}"
+            # except Exception as qe:
+            #     logger.debug("Chat2GO build_quiz_state 跳过: %s", qe)
+
+            event = MessageEvent(
+                text=content,
+                message_type=MessageType.PHOTO if media_urls else MessageType.TEXT,
+                source=self.build_source(
+                    chat_id=room_id,
+                    chat_name=room.get("name") or "调试室",
+                    chat_type="group",  # chat2go 房间是三方对话（小白+大咖+AI）
+                    user_id=msg.get("user_id"),
+                    user_name=user_label,
+                    chat_topic=room.get("industry"),
+                ),
+                message_id=str(msg_id),
+                media_urls=media_urls,
+                media_types=media_types,
+                timestamp=datetime.fromisoformat(
+                    msg["created_at"].replace("Z", "+00:00")
+                ) if msg.get("created_at") else datetime.now(),
+            )
+            await self.handle_message(event)
+        finally:
+            self._processing.discard(msg_id)
+
+    # ── 4. 出站 ──
+    async def send(
+        self,
+        chat_id: str,
+        content: str,
+        reply_to: Optional[str] = None,
+        metadata: Optional[Dict[str, Any]] = None,
+    ) -> SendResult:
+        try:
+            r = await self._sb.table("messages").insert(
+                {
+                    "room_id": chat_id,
+                    "user_id": self._expert_id,
+                    "role": "ai",
+                    "type": "text",
+                    "content": content,
+                }
+            ).execute()
+            new_id = (r.data or [{}])[0].get("id")
+            if new_id:
+                self._self_sent_ids.add(new_id)
+                # 限制集合大小
+                if len(self._self_sent_ids) > 500:
+                    self._self_sent_ids = set(list(self._self_sent_ids)[-200:])
+            # 写一行 model_usage stub，让 chat2go web UI 能渲染模型名/用量徽章
+            # hermes brain 不回传 token 计数，这里用 0；前端 fallback context window
+            try:
+                trigger = self._last_trigger.get(chat_id) or {}
