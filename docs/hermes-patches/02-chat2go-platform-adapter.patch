+def check_chat2go_requirements() -> bool:
+    """检查 supabase-py 是否可用。"""
+    try:
+        import supabase  # noqa: F401
+        return True
+    except ImportError:
+        logger.warning("Chat2GO: supabase-py 未安装（pip install supabase）")
+        return False
