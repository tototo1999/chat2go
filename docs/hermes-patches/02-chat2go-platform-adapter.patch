+    async def send(
+        self,
+        chat_id: str,
+        content: str,
+        reply_to: Optional[str] = None,
+        metadata: Optional[Dict[str, Any]] = None,
+    ) -> SendResult:
+        # ★ AI 写 todo marker parse:
+        # [TODO_APPEND]\n- task\n[/TODO_APPEND] → 加一组带日期的新 group (默认,自然语言场景用)
+        # [TODO_REPLACE]\n# 组名\n- 任务\n[/TODO_REPLACE] → 整段替换 (仅当用户明确说 rewrite/replace 时)
+        # 仅 speak2go 启用 — 防其他 3 个 Hermes(tradego/well2go/命理) 重启后跑这段逻辑
