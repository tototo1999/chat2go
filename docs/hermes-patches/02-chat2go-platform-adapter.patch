+    # ── 5. Memory 学习闭环 ──(★ 2026-05-16 加,port 自 chat2go-agent/memory.py)
+
+    # 大咖文字确认 → 写 memory(2026-05-16 约定:大咖发 "ok" = 写记忆)
+    # 触发规则:
+    #   - 整条消息(忽略大小写 + 尾部标点)等于 "ok" / "okay" → 触发,无备注
+    #   - 以 "ok:" / "ok," / "ok " 开头 → 触发,冒号/逗号/空格后内容当作大咖备注
+    _MEM_SAVE_TRAILING_PUNCT = "!.?,;。!?,;:: "
+
+    def _is_memory_save_cmd(self, text: str) -> bool:
+        t = (text or "").strip()
+        if not t:
+            return False
+        # 整条消息 = ok/okay(去尾标点 + 小写)
+        bare = t.rstrip(self._MEM_SAVE_TRAILING_PUNCT).lower()
+        if bare in ("ok", "okay"):
+            return True
+        # 以 ok / okay + 分隔符开头(后面可带备注)
+        low = t.lower()
+        for p in ("ok:", "ok:", "ok,", "ok,", "ok ", "okay:", "okay:", "okay,", "okay,", "okay "):
+            if low.startswith(p):
+                return True
+        return False
