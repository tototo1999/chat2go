+                _m = _re.search(r'\[TODO_REPLACE\](.+?)\[/TODO_REPLACE\]', content, _re.S)
+                if _m:
+                    _payload = []
+                    _cur = None
+                    for _line in _m.group(1).strip().splitlines():
+                        _line = _line.strip()
+                        if not _line:
