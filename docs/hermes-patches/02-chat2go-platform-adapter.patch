+    async def _save_context_as_memory(self, room_id: str, trigger_msg: dict):
+        """大咖发文字确认时,把最近的 AI 回复 + 触发它的问句存进 memories。"""
+        try:
+            trigger_ts = trigger_msg.get("created_at") or datetime.now(timezone.utc).isoformat()
+            # 1. 找触发命令之前最近一条 AI 消息(role='ai', channel='main')
+            r = await (
+                self._sb.table("messages")
+                .select("id,content,created_at")
+                .eq("room_id", room_id).eq("role", "ai").eq("channel", "main")
+                .lt("created_at", trigger_ts)
+                .order("created_at", desc=True).limit(1).execute()
+            )
+            if not r.data:
+                logger.info("Chat2GO 记忆命令:找不到 AI 消息,跳过")
+                return
+            ai_msg = r.data[0]
+            # 2. 找那条 AI 之前最近的 user/expert 消息(就是触发那条 AI 的"问")
+            r2 = await (
+                self._sb.table("messages")
+                .select("content,role")
+                .eq("room_id", room_id).in_("role", ["user", "expert"]).eq("channel", "main")
+                .lt("created_at", ai_msg["created_at"])
+                .order("created_at", desc=True).limit(1).execute()
+            )
+            q = (r2.data[0]["content"] if r2.data else "").strip() or "(无)"
+            content = f"问:{q}\n答:{ai_msg['content']}"
+            # 3. 防重:同一条 AI msg 只存一次
+            ex = await (
+                self._sb.table("memories").select("id")
+                .eq("source_message_id", ai_msg["id"]).limit(1).execute()
+            )
+            if ex.data:
+                logger.info("Chat2GO 记忆命令:source_message_id=%s 已存过,跳过", ai_msg["id"][:8])
+                return
+            # 4. 提取大咖触发命令里的补充说明(如 "ok: 这条特别好" / "ok 注意 X")
+            extra = (trigger_msg.get("content") or "").strip()
+            low = extra.lower()
+            for p in ("ok:", "ok:", "ok,", "ok,", "ok ", "okay:", "okay:", "okay,", "okay,", "okay "):
+                if low.startswith(p):
+                    extra = extra[len(p):].strip()
+                    break
+            else:
+                # 不带前缀(整条消息就是 ok / okay 之类)→ 没有备注
+                if low.rstrip(self._MEM_SAVE_TRAILING_PUNCT) in ("ok", "okay"):
+                    extra = ""
+            if extra:
+                content = content + f"\n大咖备注:{extra}"
+            # 5. 写入 — 默认 scope='room' 跟着房间走,reset_room 时会一起清掉。
+            # 旧实现写 scope='expert' 跨房间持久,导致 reset 后个案细节(八字/姓名等)
+                # 仍被 _prefetch_memory 拉回污染新对话。
+            # 若以后想沉淀跨房通用方法论,大咖可发"ok 通用:xxx"另开关键词路径处理。
+            await self._sb.table("memories").insert({
+                "scope": "room",
+                "scope_id": room_id,
+                "content": content,
+                "tags": ["大咖记一下", "问答对"],
+                "source_message_id": ai_msg["id"],
+            }).execute()
+            logger.info("Chat2GO 大咖文字确认 → 记下 AI msg %s (scope=room)", ai_msg["id"][:8])
+        except Exception as e:
+            logger.warning("Chat2GO _save_context_as_memory 失败(忽略): %s", e)
+
+    async def _build_quiz_state(self, room_id: str) -> Optional[str]:
+        """拼 <quiz-state> 块:让 AI 知道当前 active 题库 + pass 进度 + 开场仪式。
+
+        两种 mode:
+          - opening (本房 main 频道还没 AI 消息): 让 AI 先复述全部题目 + 求大咖说 go
+          - in-progress: 标 done/current/pending + 行为指引围绕当前题
+        """
+        try:
+            rr = await self._sb.table("rooms") \
+                .select("active_todo_template_id, focal_user_id") \
+                .eq("id", room_id).maybe_single().execute()
+            rdata = (rr.data or {}) if rr else {}
+            template_id = rdata.get("active_todo_template_id")
+            focal_user_id = rdata.get("focal_user_id")
+            if not template_id:
+                return None
+            tr = await self._sb.table("expert_todo_templates") \
+                .select("name, payload").eq("id", template_id).maybe_single().execute()
+            tdata = (tr.data or {}) if tr else {}
+            name = (tdata.get("name") or "todo 方案").strip()
+            payload = tdata.get("payload") or []
+            flat: list = []  # [(group_label, item_label), ...]
+            for g in payload:
+                for it in (g.get("items") or []):
+                    flat.append(((g.get("label") or "").strip(), (it.get("label") or "").strip()))
+            if not flat:
+                return None
+            mr = await self._sb.table("messages") \
+                .select("ratings") \
+                .eq("room_id", room_id).eq("role", "ai").eq("channel", "main") \
+                .order("created_at").execute()
+            ai_msgs = mr.data or []
+            has_ai = len(ai_msgs) > 0
+            passed = 0
+            for m in ai_msgs:
+                r = m.get("ratings") or {}
+                ups = sum(1 for v in r.values() if v == "up")
+                if ups >= 2:
+                    passed += 1
+            passed = min(passed, len(flat))
+
+            total = len(flat)
+            # 开场仪式只在小白已进房(focal_user_id 锁定)且还没 AI 消息时触发,
+            # 大咖一人在房不读题
+            if not has_ai and not focal_user_id:
+                return None
+            if not has_ai:
+                lines = [f'<quiz-state mode="opening">',
+                         f'方案:「{name}」全部 {total} 题:']
+                for idx, (gl, il) in enumerate(flat, 1):
+                    lines.append(f'  {idx}. {gl}/{il}')
+                lines += [
+                    '',
+                    '【开场仪式 - 你必须做】',
+                    '本次会话还没开始。请先:',
+                    f'1. 用一段话复述以上 {total} 道题(让大咖和小白都看一遍)',
+                    '2. 简要说明每道题的目标(≤1 句话/题)',
+                    '3. 末尾问:「大咖和小白确认题库 OK 吗?大咖说 go 就开始第一题。」',
+                    '4. **等待大咖明确说「go」/「开始」/「OK」** 才进入第一题',
+                    '5. 在大咖确认前,不要主动开始第一题',
+                    '</quiz-state>',
+                ]
+                return '\n'.join(lines)
+            lines = [
+                f'<quiz-state mode="in-progress">',
+                f'方案:「{name}」(共 {total} 题,已 pass {passed} 题)',
+                '',
+                'pass 规则:每道题 AI 回复后,大咖和小白都点 ✓(双钩 up≥2)才算 pass,自动进入下一题。',
+                '',
+                '进度:',
+            ]
+            for idx, (gl, il) in enumerate(flat):
+                if idx < passed:
+                    mark = '✓ done'
+                elif idx == passed:
+                    mark = '← 当前'
+                else:
+                    mark = 'pending'
+                lines.append(f'  [{idx+1}] {gl}/{il}   {mark}')
+            lines += [
+                '',
+                '行为指引:围绕当前题展开内容;不要主动跳到后面没开始的题;如果当前题讨论充分,提示大咖「这道题可以打 ✓ pass 进入下一题」。',
+                '</quiz-state>',
+            ]
+            return '\n'.join(lines)
+        except Exception as e:
+            logger.debug("Chat2GO _build_quiz_state 失败(忽略): %s", e)
+            return None
+
+    async def _prefetch_memory(self, room_id: str, expert_id: str, user_id: Optional[str]) -> str:
+        """拉 room/expert/user 三 scope 的 memory 拼成 markdown,空串则无 memory。"""
+        try:
+            scopes = [("room", room_id), ("expert", expert_id)]
+            if user_id:
+                scopes.append(("user", user_id))
+            sections: list[str] = []
+            for scope, scope_id in scopes:
+                r = await (
+                    self._sb.table("memories")
+                    .select("content,tags,created_at")
+                    .eq("scope", scope).eq("scope_id", scope_id)
+                    .order("updated_at", desc=True).limit(10).execute()
+                )
+                rows = r.data or []
+                if not rows:
+                    continue
+                label = {"room": "本调试室记忆", "expert": "大咖个人记忆", "user": "小白个人记忆"}[scope]
+                lines = [f"## {label}"]
+                for row in rows:
+                    tags = row.get("tags") or []
+                    tag_str = f" [{', '.join(tags)}]" if tags else ""
+                    lines.append(f"- {row['content']}{tag_str}")
+                sections.append("\n".join(lines))
+            return "\n\n".join(sections)
+        except Exception as e:
+            logger.debug("Chat2GO prefetch_memory 失败(忽略): %s", e)
+            return ""
+
+    async def _sync_memory(self, room_id: str, expert_id: str, expert_message: str,
+                          ai_message: str, source_message_id: Optional[str]) -> None:
+        """大咖发言后异步:LLM 提取 fact → 写 memories 表。"""
+        try:
+            if not expert_message.strip():
+                return
+            dialogue = f"大咖:{expert_message}\nAI:{ai_message}" if ai_message else f"大咖:{expert_message}"
+            anthropic_key = os.getenv("ANTHROPIC_API_KEY", "")
+            if not anthropic_key:
+                logger.warning("Chat2GO sync_memory 跳过:无 ANTHROPIC_API_KEY")
+                return
+            extract_prompt = (
+                "你是一个知识提取助手。根据下面这段对话,判断大咖的发言是否包含值得长期记住的事实、规则或偏好。\n"
+                "\n判断标准(满足任一即提取):\n"
+                "- 大咖纠正了 AI 的回答\n- 大咖补充了专业知识或行业规则\n"
+                "- 大咖表达了明确的偏好(风格、用词、禁忌等)\n"
+                "- 大咖提到了关于这个房间/用户的重要背景信息\n"
+                "\n以 JSON 数组输出,每条格式:"
+                '[{"content":"一句话描述这个事实","scope":"room|expert","tags":["标签1","标签2"]}]'
+                "\nscope 说明:room=只对这个调试室有效;expert=大咖个人通用知识(跨房间有效)"
+                "\n如果没有值得记住的内容,输出空数组 []。只输出 JSON,不要任何解释。"
+                f"\n\n---对话---\n{dialogue}\n"
+            )
+            # 用 httpx 直接调 Anthropic API,asyncio.wait 硬超时 25s
+            async def _call():
+                async with httpx.AsyncClient(timeout=30) as c:
+                    resp = await c.post(
+                        "https://api.anthropic.com/v1/messages",
+                        headers={
+                            "x-api-key": anthropic_key,
+                            "anthropic-version": "2023-06-01",
+                            "content-type": "application/json",
+                        },
+                        json={
+                            "model": "claude-haiku-4-5-20251001",
+                            "max_tokens": 2048,
+                            "system": "你是知识提取助手,只输出 JSON。",
+                            "messages": [{"role": "user", "content": extract_prompt}],
+                        },
+                    )
+                    resp.raise_for_status()
+                    return resp.json()
+            llm_task = asyncio.create_task(_call())
+            done, pending = await asyncio.wait({llm_task}, timeout=25)
+            if not done:
+                logger.info("Chat2GO sync_memory LLM 硬超时,放弃")
+                llm_task.cancel()
+                return
+            result = llm_task.result()
+            raw = ""
+            for block in result.get("content", []):
+                if block.get("type") == "text":
+                    raw = block.get("text", "")
+                    break
+            raw = raw.strip()
+            if not raw:
+                return
+            m = re.search(r"\[.*\]", raw, re.DOTALL)
+            if not m:
+                logger.info("Chat2GO sync_memory:LLM 输出无 [...] 数组,raw=%r", raw[:200])
+                return
+            try:
+                items = json.loads(m.group())
+            except json.JSONDecodeError as e:
+                logger.info("Chat2GO sync_memory JSON 解析失败:%s; raw=%r", e, raw[:200])
+                return
+            if not isinstance(items, list) or not items:
+                logger.info("Chat2GO sync_memory:LLM 判定无事实可记")
+                return
+            for item in items:
+                try:
+                    if not isinstance(item, dict):
+                        continue
+                    content = (item.get("content") or "").strip()
+                    scope = item.get("scope", "room")
+                    tags = item.get("tags") or []
+                    if not content:
+                        continue
+                    if scope not in ("room", "expert"):
+                        scope = "room"
+                    scope_id = room_id if scope == "room" else expert_id
+                    # 去重:content 完全相同跳过
+                    existing = await (
+                        self._sb.table("memories").select("id")
+                        .eq("scope", scope).eq("scope_id", scope_id)
+                        .eq("content", content).limit(1).execute()
+                    )
+                    if existing.data:
+                        continue
+                    row = {"scope": scope, "scope_id": scope_id, "content": content, "tags": tags}
+                    if source_message_id:
+                        row["source_message_id"] = source_message_id
+                    await self._sb.table("memories").insert(row).execute()
+                    logger.info("Chat2GO 写入记忆 [%s]: %s", scope, content[:60])
+                except Exception as ie:
+                    logger.info("Chat2GO sync_memory 单条失败(跳过):%s; item=%r", ie, item)
+        except Exception as e:
+            logger.warning("Chat2GO sync_memory 失败(忽略):%s", e)
+
+    # ────────────────────────────────────────────────────────────
+    # tradego 合同生成 (绕开 brain 的关键词拦截路径)
+    # 触发: room.product=='tradego' AND content 含合同/PI 关键词
+    # 流程: DS V3 抽 JSON → contract_lib 渲染 PDF → chat2go_upload 上传 → markdown 回复
+    # ────────────────────────────────────────────────────────────
+    _CONTRACT_KEYWORDS = (
+        "出合同", "做合同", "出张合同", "做张合同", "生成合同", "做个合同", "帮我出合同",
+        # 单证关键词:无空格 + 带空格 + 大写,大小写不敏感(content 已 .lower())
+        "做pi", "出pi", "做ci", "出ci", "做pl", "出pl", "做ic", "出ic",
+        "做 pi", "出 pi", "做 ci", "出 ci", "做 pl", "出 pl",
+        "出个 pi", "做张 pi", "发个 pi", "做张 ci", "做张 pl",
+        "做 invoice", "出 invoice", "做invoice", "出invoice",
+        "全套单证", "全套单据", "出全套", "做全套",
+        "render contract", "make contract", "generate contract",
+        "generate pi", "proforma invoice", "commercial invoice", "packing list",
+        "tradego-contract",  # skill 名直接触发
+    )
+
+    def _matches_contract_intent(self, content: str) -> bool:
+        if not content:
+            return False
+        c = content.lower()
+        return any(kw.lower() in c for kw in self._CONTRACT_KEYWORDS)
+
+    async def _try_handle_tradego_contract(
+        self, room: dict, room_id: str, msg: dict, content: str
+    ) -> bool:
+        if (room or {}).get("product") != "tradego":
+            return False
+        if not self._matches_contract_intent(content):
+            return False
+        logger.info("Chat2GO tradego-contract: 拦截 room=%s msg=%s", room_id, msg.get("id"))
+        try:
+            loop = asyncio.get_running_loop()
+            contract_data = await loop.run_in_executor(None, self._extract_contract_json, content)
+            if not contract_data:
+                await self.send(room_id, "我没能从消息里抽出完整的合同字段(卖方/买方/产品/单价等),请补全后重试。")
+                return True
+            pdf_path = await loop.run_in_executor(None, self._render_contract_pdf, contract_data)
+            public_url = await loop.run_in_executor(None, self._upload_contract_pdf, pdf_path, room_id)
+            reply = self._format_contract_reply(contract_data, contract_data.get("_stats") or {}, public_url)
+            await self.send(room_id, reply)
+            return True
+        except Exception as e:
+            logger.exception("Chat2GO tradego-contract 失败: %s", e)
+            try:
+                await self.send(room_id, f"合同生成失败: `{type(e).__name__}: {e}`")
+            except Exception:
+                pass
+            return True
+
+    def _extract_contract_json(self, text: str):
+        from contract_generator import extract_contract_data
+        return extract_contract_data(text)
+
+    def _render_contract_pdf(self, contract_data):
+        import time, uuid
+        from contract_lib import PDFContractGenerator
+        ctype_raw = (contract_data.get("customer_type") or "").lower()
+        if "inus" in ctype_raw:
+            contract_type = "inus"
+        elif "jincheng" in ctype_raw or "金城" in ctype_raw:
+            contract_type = "jincheng"
+        elif "neutral" in ctype_raw or "中性" in ctype_raw:
+            contract_type = "neutral"
+        elif "daelim" in ctype_raw:
+            contract_type = "daelim"
+        else:
+            contract_type = "standard"
+        out_path = f"/tmp/tradego_contract_{int(time.time())}_{uuid.uuid4().hex[:6]}.pdf"
+        gen = PDFContractGenerator()
+        stats = gen.generate(contract_data, out_path, contract_type=contract_type)
+        contract_data["_stats"] = stats
+        return out_path
+
+    def _upload_contract_pdf(self, pdf_path, room_id):
+        from chat2go_upload import upload_pdf_to_chat
+        return upload_pdf_to_chat(pdf_path, room_id=room_id, name_hint="contract")
+
+    def _format_contract_reply(self, data, stats, url):
+        return (
+            "✅ **合同已生成**\n\n"
+            "| 字段 | 值 |\n|---|---|\n"
+            f"| 合同号 | {data.get('contract_number', '')} |\n"
+            f"| 卖方 | {data.get('seller', '')} |\n"
+            f"| 买方 | {data.get('buyer', '')} |\n"
+            f"| 客户类型 | {data.get('customer_type', '')} |\n"
+            f"| 总金额 | ¥{stats.get('total_amount', 0):.2f} |\n"
+            f"| 总箱数 | {stats.get('total_boxes', 0)} 箱 |\n"
+            f"| 总柜数 | {stats.get('total_containers', 0):.1f} 柜 |\n"
+            f"| 总平方 | {stats.get('total_sqm', 0):.2f} ㎡ |\n\n"
+            f"📄 [下载合同 PDF]({url})"
+        )
+
